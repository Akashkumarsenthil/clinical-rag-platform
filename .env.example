# ── LLM Backend ──────────────────────────────────────────────────────────────
# Choose "groq" (free API, fast) or "ollama" (local, fully offline)
LLM_BACKEND=groq

# Groq — free at https://console.groq.com (no credit card required)
GROQ_API_KEY=gsk_your_key_here
CHAT_MODEL=llama-3.3-70b-versatile

# Ollama — only needed when LLM_BACKEND=ollama
# Run: docker compose --profile ollama up ollama
# Then: docker exec clinical-ollama ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embeddings (local, no API key needed) ────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Local (default with docker compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=clinical_docs

# Qdrant Cloud (free 1GB tier — https://cloud.qdrant.io)
# QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io
# QDRANT_API_KEY=your_qdrant_cloud_key

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local (default with docker compose)
DATABASE_URL=postgresql://clinical:clinical@localhost:5432/clinical_rag

# Neon / Supabase (free hosted Postgres)
# DATABASE_URL=postgresql://user:pass@host.neon.tech/clinical_rag?sslmode=require

# ── PDF Storage ───────────────────────────────────────────────────────────────
PDF_STORAGE_DIR=/app/uploads

# ── Runtime ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
