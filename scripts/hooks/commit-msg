#!/bin/sh
# Reject commit messages with unwanted co-author trailers.
# Install: bash scripts/install-hooks.sh

if grep -qiE 'co-authored-by:.*cursor|cursoragent@cursor\.com' "$1"; then
  echo "ERROR: Commit message contains a blocked co-author trailer."
  echo "Remove the Co-authored-by line before committing."
  exit 1
fi

exit 0
